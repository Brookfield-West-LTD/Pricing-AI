# ── Database ──────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/pricing_ai"
DIRECT_URL="postgresql://user:password@localhost:5432/pricing_ai"

# ── Redis (local dev) ────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"
# Production (Upstash):
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ── AWS ──────────────────────────────────────────────────────────
AWS_REGION="eu-central-1"
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Bedrock ───────────────────────────────────────────────────────
BEDROCK_AGENT_ID=
BEDROCK_AGENT_ALIAS_ID=
BEDROCK_KNOWLEDGE_BASE_ID=
BEDROCK_MODEL_ID="anthropic.claude-sonnet-4-5"

# ── S3 ────────────────────────────────────────────────────────────
S3_BUCKET_UPLOADS="pricing-ai-uploads"
S3_BUCKET_REPORTS="pricing-ai-reports"
S3_BUCKET_KNOWLEDGE_BASE="pricing-ai-knowledge-base"

# ── Voice ─────────────────────────────────────────────────────────
NOVA_SONIC_MODEL_ID="amazon.nova-sonic-v1:0"

# ── External APIs ─────────────────────────────────────────────────
NASA_POWER_API_URL="https://power.larc.nasa.gov/api/temporal/daily/point"
PVGIS_API_URL="https://re.jrc.ec.europa.eu/api/v5_2"

# ── App ───────────────────────────────────────────────────────────
API_PORT=3001
NODE_ENV="development"
NEXT_PUBLIC_API_URL="http://localhost:3001"

# ── Payments v1+ ─────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
